user tchiaze;
worker_processes 4;
pid /tmp/nginx.pid;
worker_rlimit_nofile 65535;

events {
    worker_connections 16384;
    use epoll;
}

http {
    access_log off;
    error_log /home/tchiaze/Master2_ACS_SUPAERO_ISAE/Stage/Prototype_sendfd/Eval_perf/nginx_error.log warn;
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout 65;
    keepalive_requests 100000;
    types_hash_max_size 2048;

    # FAIR COMPARISON: Disable buffering to match direct server behavior
    proxy_buffering off;
    proxy_request_buffering off;

    # UPSTREAM_PLACEHOLDER

    server {
        listen 8445 ssl backlog=16384;
        ssl_certificate /home/tchiaze/Master2_ACS_SUPAERO_ISAE/Stage/Prototype_sendfd/libtlspeek/certs/server.crt;
        ssl_certificate_key /home/tchiaze/Master2_ACS_SUPAERO_ISAE/Stage/Prototype_sendfd/libtlspeek/certs/server.key;
        ssl_protocols TLSv1.2 TLSv1.3;
        ssl_ciphers HIGH:!aNULL:!MD5;
        ssl_prefer_server_ciphers off;

        # Disable session caching for fair TLS comparison
        ssl_session_cache off;

        location / {
            # Forward to backend workers
            proxy_pass http://backend;
            proxy_http_version 1.1;
            proxy_set_header Connection "";
            proxy_set_header Host $host;
            proxy_connect_timeout 10s;
            proxy_send_timeout 30s;
            proxy_read_timeout 30s;
        }
    }
}
