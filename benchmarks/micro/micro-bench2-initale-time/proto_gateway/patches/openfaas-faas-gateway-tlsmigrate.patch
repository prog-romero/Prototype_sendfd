index 0000000..dc9899f
--- /dev/null
+++ b/gateway/tlsmigrate/tlsmigrate.h
@@ -0,0 +1,49 @@
+#ifndef TLSMIGRATE_H
+#define TLSMIGRATE_H
+
+#include <stdint.h>
+#include <stddef.h>
+
+#include <tlspeek/tlspeek.h>
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+#define TLSMIGRATE_MAGIC   0x544D4754U /* 'TMGT' */
+#define TLSMIGRATE_VERSION 1U
+
+typedef struct tlsmigrate_ctx tlsmigrate_ctx_t;
+
+typedef struct {
+    uint32_t magic;
+    uint32_t version;
+    uint64_t top1_rdtsc;
+    uint64_t cntfrq;
+    uint8_t top1_set;
+    uint8_t _pad[7];
+    tlspeek_serial_t serial;
+} tlsmigrate_payload_t;
+
+tlsmigrate_ctx_t* tlsmigrate_new_ctx(const char* cert_file, const char* key_file);
+void tlsmigrate_free_ctx(tlsmigrate_ctx_t* ctx);
+
+int tlsmigrate_accept_peek_export(
+    tlsmigrate_ctx_t* ctx,
+    int listen_fd,
+    unsigned char* headers_buf,
+    size_t headers_buf_sz,
+    int* headers_len_out,
+    tlsmigrate_payload_t* payload_out);
+
