diff --git a/gateway/tlsmigrate/config.go b/gateway/tlsmigrate/config.go
new file mode 100644
index 0000000..6fa8824
--- /dev/null
+++ b/gateway/tlsmigrate/config.go
@@ -0,0 +1,123 @@
+package tlsmigrate
+
+import (
+	"bytes"
+	"errors"
+	"fmt"
+	"log"
+	"os"
+	"strconv"
+	"strings"
+)
+
+type Config struct {
+	ListenAddr   string
+	CertFile     string
+	KeyFile      string
+	SocketDir    string
+	MaxPeekBytes int
+}
+
+func MaybeStartFromEnv() {
+	cfg, err := configFromEnv()
+	if err != nil {
+		log.Printf("[tlsmigrate] disabled: %v", err)
+		return
+	}
+
+	go func() {
+		log.Printf("[tlsmigrate] enabled listen=%s socket_dir=%s", cfg.ListenAddr, cfg.SocketDir)
+		if err := Run(cfg); err != nil {
+			log.Printf("[tlsmigrate] stopped: %v", err)
+		}
+	}()
+}
+
+func configFromEnv() (Config, error) {
+	listen := getenv("TLSMIGRATE_LISTEN", ":9443")
+	cert := getenv("TLSMIGRATE_CERT", "/certs/server.crt")
+	key := getenv("TLSMIGRATE_KEY", "/certs/server.key")
+	sockDir := getenv("TLSMIGRATE_SOCKET_DIR", "/run/tlsmigrate")
+
+	maxPeek := 8192
+	if v := strings.TrimSpace(os.Getenv("TLSMIGRATE_PEEK_BYTES")); v != "" {
+		parsed, err := strconv.Atoi(v)
+		if err != nil || parsed <= 0 {
+			return Config{}, fmt.Errorf("invalid TLSMIGRATE_PEEK_BYTES=%q", v)
+		}
+		maxPeek = parsed
+	}
+
+	if strings.TrimSpace(os.Getenv("TLSMIGRATE_ENABLE")) != "1" {
+		return Config{}, errors.New("TLSMIGRATE_ENABLE not set")
+	}
+	if listen == "" {
+		return Config{}, errors.New("TLSMIGRATE_LISTEN empty")
+	}
+	if cert == "" || key == "" {
+		return Config{}, errors.New("TLSMIGRATE_CERT/TLSMIGRATE_KEY empty")
+	}
+	if sockDir == "" {
+		return Config{}, errors.New("TLSMIGRATE_SOCKET_DIR empty")
+	}
+
+	return Config{
+		ListenAddr:   listen,
+		CertFile:     cert,
+		KeyFile:      key,
+		SocketDir:    sockDir,
+		MaxPeekBytes: maxPeek,
+	}, nil
+}
+
+func getenv(key, def string) string {
+	if v := strings.TrimSpace(os.Getenv(key)); v != "" {
+		return v
+	}
+	return def
+}
+
+func parseFunctionName(peeked []byte) (string, bool) {
+	// We only need the request line: "METHOD /function/<name> HTTP/1.1".
+	lineEnd := bytes.Index(peeked, []byte("\r\n"))
+	if lineEnd < 0 {
+		lineEnd = bytes.IndexByte(peeked, '\n')
+	}
+	if lineEnd < 0 {
+		lineEnd = len(peeked)
+	}
+	line := bytes.TrimSpace(peeked[:lineEnd])
+	parts := bytes.SplitN(line, []byte(" "), 3)
+	if len(parts) < 2 {
+		return "", false
+	}
+	path := string(parts[1])
+	if !strings.HasPrefix(path, "/function/") {
+		return "", false
+	}
+	rest := strings.TrimPrefix(path, "/function/")
+	end := len(rest)
+	for i := 0; i < len(rest); i++ {
+		switch rest[i] {
+		case '/', '?', ' ':
+			end = i
+			i = len(rest)
+		}
+	}
+	name := rest[:end]
+	if name == "" {
+		return "", false
+	}
+	for _, ch := range name {
+		if (ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z') || (ch >= '0' && ch <= '9') {
+			continue
+		}
+		switch ch {
+		case '-', '_', '.':
+			continue
+		default:
+			return "", false
+		}
+	}
+	return name, true
+}
diff --git a/gateway/tlsmigrate/server_cgo.go b/gateway/tlsmigrate/server_cgo.go
new file mode 100644
index 0000000..03e5788
--- /dev/null
+++ b/gateway/tlsmigrate/server_cgo.go
@@ -0,0 +1,92 @@
+package tlsmigrate
+
+/*
+#include "tlsmigrate.h"
+#include <stdlib.h>
+*/
+import "C"
+
+import (
+	"fmt"
+	"log"
+	"net"
+	"os"
+	"path/filepath"
+	"syscall"
+	"unsafe"
+)
+
+func Run(cfg Config) error {
+	if err := os.MkdirAll(cfg.SocketDir, 0o777); err != nil {
+		log.Printf("[tlsmigrate] warning: could not mkdir %s: %v", cfg.SocketDir, err)
+	}
+
+	ln, err := net.Listen("tcp", cfg.ListenAddr)
+	if err != nil {
+		return fmt.Errorf("listen %s: %w", cfg.ListenAddr, err)
+	}
+	defer ln.Close()
+
+	tcpLn, ok := ln.(*net.TCPListener)
+	if !ok {
+		return fmt.Errorf("unexpected listener type %T", ln)
+	}
+
+	f, err := tcpLn.File()
+	if err != nil {
+		return fmt.Errorf("listener file: %w", err)
+	}
+	defer f.Close()
+	_ = tcpLn.Close()
+
+	listenFD := int(f.Fd())
+
+	cCert := C.CString(cfg.CertFile)
+	defer C.free(unsafe.Pointer(cCert))
+	cKey := C.CString(cfg.KeyFile)
+	defer C.free(unsafe.Pointer(cKey))
+
+	ctx := C.tlsmigrate_new_ctx(cCert, cKey)
+	if ctx == nil {
+		return fmt.Errorf("tlsmigrate_new_ctx failed")
+	}
+	defer C.tlsmigrate_free_ctx(ctx)
+
+	headerBuf := make([]byte, cfg.MaxPeekBytes)
+	payload := (*C.tlsmigrate_payload_t)(C.malloc(C.size_t(C.sizeof_tlsmigrate_payload_t)))
+	if payload == nil {
+		return fmt.Errorf("malloc payload failed")
+	}
+	defer C.free(unsafe.Pointer(payload))
+
+	for {
+		var hdrLen C.int
+		clientFD := C.tlsmigrate_accept_peek_export(
+			ctx,
+			C.int(listenFD),
+			(*C.uchar)(unsafe.Pointer(&headerBuf[0])),
+			C.size_t(len(headerBuf)),
+			&hdrLen,
+			payload,
+		)
+
+		if clientFD < 0 {
+			continue
+		}
+
+		fnName, ok := parseFunctionName(headerBuf[:int(hdrLen)])
+		if !ok {
+			_ = syscall.Close(int(clientFD))
+			continue
+		}
+
+		sockPath := filepath.Join(cfg.SocketDir, fnName+".sock")
+		cSock := C.CString(sockPath)
+		rc := C.tlsmigrate_send_fd(cSock, clientFD, payload, C.size_t(C.sizeof_tlsmigrate_payload_t))
+		C.free(unsafe.Pointer(cSock))
+		if rc != 0 {
+			// tlsmigrate_send_fd is expected to close clientFD on all paths.
+			log.Printf("[tlsmigrate] sendfd failed fn=%s sock=%s", fnName, sockPath)
+		}
+	}
+}
diff --git a/gateway/tlsmigrate/tlsmigrate.c b/gateway/tlsmigrate/tlsmigrate.c
new file mode 100644
index 0000000..5755ce5
--- /dev/null
+++ b/gateway/tlsmigrate/tlsmigrate.c
@@ -0,0 +1,270 @@
+#include "tlsmigrate.h"
+
+#ifndef HAVE_SECRET_CALLBACK
+#define HAVE_SECRET_CALLBACK
+#endif
+#ifndef WOLFSSL_KEYLOG_EXPORT
+#define WOLFSSL_KEYLOG_EXPORT
+#endif
+
+#include <wolfssl/options.h>
+#include <wolfssl/ssl.h>
+
+#include <tlspeek/sendfd.h>
+#include <tlspeek/unix_socket.h>
+
+#include <errno.h>
+#include <stdio.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+
+#include <sched.h>
+#include <sys/ioctl.h>
+#include <sys/socket.h>
+
+struct tlsmigrate_ctx {
+    WOLFSSL_CTX* wctx;
+};
+
+static uint64_t bench2_rdtsc(void) {
+#if defined(__x86_64__) || defined(__i386__)
+    uint32_t lo, hi;
+    __asm__ volatile ("rdtsc" : "=a"(lo), "=d"(hi));
+    return ((uint64_t)hi << 32) | lo;
+#elif defined(__aarch64__)
+    uint64_t val;
+    __asm__ volatile ("isb; mrs %0, cntvct_el0" : "=r"(val));
+    return val;
+#else
+# error "bench2_rdtsc: unsupported architecture"
+#endif
+}
+
+static uint64_t bench2_cntfrq(void) {
+#if defined(__aarch64__)
+    uint64_t val;
+    __asm__ volatile ("mrs %0, cntfrq_el0" : "=r"(val));
+    return val;
+#else
+    return 1000000000ULL;
+#endif
+}
+
+static void bench2_wait_readable(int fd) {
+    int avail = 0;
+    do {
+        ioctl(fd, FIONREAD, &avail);
+        if (avail > 0) {
+            return;
+        }
+        sched_yield();
+    } while (1);
+}
+
+static int is_function_name_char(unsigned char ch) {
+    return ((ch >= 'a' && ch <= 'z') ||
+            (ch >= 'A' && ch <= 'Z') ||
+            (ch >= '0' && ch <= '9') ||
+            ch == '-' || ch == '_' || ch == '.');
+}
+
+/*
+ * Return the minimal plaintext prefix length that contains a complete
+ * `/function/<name>` token in the request line.
+ *
+ * > 0: exact prefix length to keep
+ *   0: need more plaintext bytes before routing safely
+ *  -1: invalid request line for the prototype routing contract
+ */
+static int function_name_prefix_len(const unsigned char* buf, size_t len) {
+    static const char prefix[] = "/function/";
+    const size_t prefix_len = sizeof(prefix) - 1;
+    const unsigned char* p = buf;
+    const unsigned char* end = buf + len;
+
+    while (p < end && (*p == '\r' || *p == '\n')) {
+        p++;
+    }
+
+    const unsigned char* method_sep = memchr(p, ' ', (size_t)(end - p));
+    if (!method_sep) {
+        return 0;
+    }
+
+    const unsigned char* path = method_sep + 1;
+    if (path >= end) {
+        return 0;
+    }
+
+    size_t avail = (size_t)(end - path);
+    size_t compare_len = (avail < prefix_len) ? avail : prefix_len;
+    if (compare_len > 0 && memcmp(path, prefix, compare_len) != 0) {
+        return -1;
+    }
+    if (avail < prefix_len) {
+        return 0;
+    }
+
+    const unsigned char* name = path + prefix_len;
+    if (name >= end) {
+        return 0;
+    }
+
+    const unsigned char* cursor = name;
+    while (cursor < end && is_function_name_char(*cursor)) {
+        cursor++;
+    }
+
+    if (cursor == name) {
+        return -1;
+    }
+    if (cursor >= end) {
+        return 0;
+    }
+
+    switch (*cursor) {
+    case ' ':
+    case '\r':
+    case '\n':
+    case '/':
+    case '?':
+        return (int)(cursor - buf);
+    default:
+        return -1;
+    }
+}
+
+tlsmigrate_ctx_t* tlsmigrate_new_ctx(const char* cert_file, const char* key_file) {
+    if (!cert_file || !key_file) {
+        return NULL;
+    }
+
+    wolfSSL_Init();
+
+    tlsmigrate_ctx_t* ctx = (tlsmigrate_ctx_t*)calloc(1, sizeof(*ctx));
+    if (!ctx) {
+        return NULL;
+    }
+
+    ctx->wctx = wolfSSL_CTX_new(wolfSSLv23_server_method());
+    if (!ctx->wctx) {
+        free(ctx);
+        return NULL;
+    }
+
+    if (wolfSSL_CTX_use_certificate_file(ctx->wctx, cert_file, SSL_FILETYPE_PEM) != SSL_SUCCESS) {
+        fprintf(stderr, "[tlsmigrate] wolfSSL_CTX_use_certificate_file failed: %s\n", cert_file);
+        wolfSSL_CTX_free(ctx->wctx);
+        free(ctx);
+        return NULL;
+    }
+
+    if (wolfSSL_CTX_use_PrivateKey_file(ctx->wctx, key_file, SSL_FILETYPE_PEM) != SSL_SUCCESS) {
+        fprintf(stderr, "[tlsmigrate] wolfSSL_CTX_use_PrivateKey_file failed: %s\n", key_file);
+        wolfSSL_CTX_free(ctx->wctx);
+        free(ctx);
+        return NULL;
+    }
+
+    return ctx;
+}
+
+void tlsmigrate_free_ctx(tlsmigrate_ctx_t* ctx) {
+    if (!ctx) {
+        return;
+    }
+    if (ctx->wctx) {
+        wolfSSL_CTX_free(ctx->wctx);
+    }
+    free(ctx);
+}
+
+static void set_cipher_suite_from_name(tlspeek_ctx_t* peek_ctx, const char* cipher_name) {
+    if (!peek_ctx) {
+        return;
+    }
+
+    if (!cipher_name) {
+        peek_ctx->cipher_suite = TLSPEEK_AES_256_GCM;
+        return;
+    }
+
+    if (strstr(cipher_name, "CHACHA20")) {
+        peek_ctx->cipher_suite = TLSPEEK_CHACHA20_POLY;
+    } else if (strstr(cipher_name, "AES-128")) {
+        peek_ctx->cipher_suite = TLSPEEK_AES_128_GCM;
+    } else {
+        peek_ctx->cipher_suite = TLSPEEK_AES_256_GCM;
+    }
+}
+
+int tlsmigrate_accept_peek_export(
+    tlsmigrate_ctx_t* ctx,
+    int listen_fd,
+    unsigned char* headers_buf,
+    size_t headers_buf_sz,
+    int* headers_len_out,
+    tlsmigrate_payload_t* payload_out) {
+
+    if (!ctx || !ctx->wctx || listen_fd < 0 || !headers_buf || headers_buf_sz == 0 || !payload_out) {
+        errno = EINVAL;
+        return -1;
+    }
+
+    int client_fd = accept(listen_fd, NULL, NULL);
+    if (client_fd < 0) {
+        return -1;
+    }
+
+    WOLFSSL* ssl = wolfSSL_new(ctx->wctx);
+    if (!ssl) {
+        close(client_fd);
+        errno = ENOMEM;
+        return -1;
+    }
+    wolfSSL_set_fd(ssl, client_fd);
+
+    tlspeek_ctx_t peek_ctx;
+    memset(&peek_ctx, 0, sizeof(peek_ctx));
+    peek_ctx.tcp_fd = client_fd;
+    peek_ctx.ssl = ssl;
+
+    // Make ctx available to the callback (arg preferred, ex_data fallback)
+    wolfSSL_set_ex_data(ssl, 0, &peek_ctx);
+
+    // Register the TLS 1.3 secret callback before handshake
+    wolfSSL_set_tls13_secret_cb(ssl, tlspeek_keylog_cb, &peek_ctx);
+
+    int ret = wolfSSL_accept(ssl);
+    if (ret != SSL_SUCCESS) {
+        wolfSSL_free(ssl);
+        close(client_fd);
+        return -1;
+    }
+
+    bench2_wait_readable(client_fd);
+    uint64_t top1 = bench2_rdtsc();
+    uint64_t cntfrq = bench2_cntfrq();
+
+    if (!peek_ctx.keys_ready) {
+        wolfSSL_set_quiet_shutdown(ssl, 1);
+        wolfSSL_free(ssl);
+        close(client_fd);
+        errno = EPROTO;
+        return -1;
+    }
+
+    const char* cipher_name = wolfSSL_get_cipher_name(ssl);
+    set_cipher_suite_from_name(&peek_ctx, cipher_name);
+
+    memset(headers_buf, 0, headers_buf_sz);
+
+    size_t peek_step = headers_buf_sz < 1024 ? headers_buf_sz : 1024;
+    size_t peek_cap = peek_step;
+    int headers_len = -1;
+    for (;;) {
+        headers_len = tls_read_peek(&peek_ctx, (uint8_t*)headers_buf, peek_cap);
+        if (headers_len <= 0) {
+            break;
+        }
+
+        int route_len = function_name_prefix_len((const unsigned char*)headers_buf, (size_t)headers_len);
+        if (route_len > 0) {
+            headers_len = route_len;
+            break;
+        }
+
+        if (route_len < 0 || peek_cap >= headers_buf_sz || headers_len < (int)peek_cap) {
+            headers_len = -1;
+            errno = EPROTO;
+            break;
+        }
+
+        size_t next_cap = peek_cap + peek_step;
+        if (next_cap > headers_buf_sz) {
+            next_cap = headers_buf_sz;
+        }
+        if (next_cap == peek_cap) {
+            headers_len = -1;
+            errno = EPROTO;
+            break;
+        }
+        peek_cap = next_cap;
+    }
+
+    if (headers_len <= 0) {
+        wolfSSL_set_quiet_shutdown(ssl, 1);
+        wolfSSL_free(ssl);
+        close(client_fd);
+        errno = EIO;
+        return -1;
+    }
+
+    if (headers_len_out) {
+        *headers_len_out = headers_len;
+    }
+
+    memset(payload_out, 0, sizeof(*payload_out));
+    payload_out->magic = TLSMIGRATE_MAGIC;
+    payload_out->version = TLSMIGRATE_VERSION;
+    payload_out->top1_rdtsc = top1;
+    payload_out->cntfrq = cntfrq;
+    payload_out->top1_set = 1;
+
+    tlspeek_serial_t* serial = &payload_out->serial;
+    memset(serial, 0, sizeof(*serial));
+    serial->magic = TLSPEEK_MAGIC;
+    serial->cipher_suite = (uint32_t)peek_ctx.cipher_suite;
+    memcpy(serial->client_write_key, peek_ctx.client_write_key,
+           sizeof(serial->client_write_key));
+    memcpy(serial->client_write_iv, peek_ctx.client_write_iv,
+           sizeof(serial->client_write_iv));
+    serial->read_seq_num = peek_ctx.read_seq_num;
+    serial->blob_sz = TLSPEEK_MAX_EXPORT_SZ;
+
+    int export_ret = wolfSSL_tls_export(ssl, serial->tls_blob, &serial->blob_sz);
+    if (export_ret < 0) {
+        wolfSSL_set_quiet_shutdown(ssl, 1);
+        wolfSSL_free(ssl);
+        close(client_fd);
+        errno = EIO;
+        return -1;
+    }
+
+    serial->request_len = 0;
+
+    // Detach and free wolfSSL session without alerts; ownership of client_fd remains.
+    wolfSSL_set_quiet_shutdown(ssl, 1);
+    wolfSSL_set_fd(ssl, -1);
+    wolfSSL_free(ssl);
+    tlspeek_free(&peek_ctx);
+
+    return client_fd;
+}
+
+int tlsmigrate_send_fd(
+    const char* unix_sock_path,
+    int client_fd,
+    const tlsmigrate_payload_t* payload,
+    size_t payload_len) {
+
+    if (!unix_sock_path || !payload || payload_len == 0 || client_fd < 0) {
+        if (client_fd >= 0) {
+            close(client_fd);
+        }
+        errno = EINVAL;
+        return -1;
+    }
+
+    int uds_fd = unix_client_connect(unix_sock_path);
+    if (uds_fd < 0) {
+        close(client_fd);
+        return -1;
+    }
+
+    int rc = sendfd_with_state(uds_fd, client_fd, payload, payload_len);
+    close(uds_fd);
+
+    // sendfd_with_state closes client_fd on success.
+    if (rc != 0) {
+        // In case sendfd_with_state failed before closing.
+        close(client_fd);
+        return -1;
+    }
+
+    return 0;
+}
diff --git a/gateway/tlsmigrate/tlsmigrate.h b/gateway/tlsmigrate/tlsmigrate.h
